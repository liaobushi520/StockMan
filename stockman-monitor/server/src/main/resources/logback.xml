<configuration>
    <property name="LOG_DIR" value="${stockman.log.dir:-server/logs}"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/server.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{48} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="SYNC_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/sync.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{48} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.liaobusi.stockman.monitor.HistoryStockSync" level="INFO" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="SYNC_FILE"/>
    </logger>

    <logger name="com.liaobusi.stockman.monitor.RealtimeStockSync" level="INFO" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="SYNC_FILE"/>
    </logger>

    <logger name="HistoryStockStrategies" level="INFO" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="SYNC_FILE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
