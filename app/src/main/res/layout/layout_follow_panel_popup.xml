<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#333"
    android:orientation="vertical"
    android:minWidth="220dp">

    <TextView
        android:id="@+id/pinTopBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="置顶"
        android:textColor="#fff"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/pinBottomBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="置底"
        android:textColor="#fff"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/markColorBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="标色"
        android:textColor="#fff"
        android:textSize="18sp" />

    <LinearLayout
        android:id="@+id/colorPaletteRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/palettePick1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick4"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick5"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/palettePick6"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick7"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick8"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick9"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />

            <View
                android:id="@+id/palettePick10"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:foreground="?android:attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/unfollowBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="取关"
        android:textColor="#fff"
        android:textSize="18sp" />
</LinearLayout>
