<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yd_page_bg"
    android:fitsSystemWindows="true"
    android:focusableInTouchMode="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/yd_accent"
        android:elevation="4dp"
        app:navigationIconTint="@android:color/white"
        app:subtitleTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
        app:subtitleTextColor="#CCFFFFFF"
        app:title="@string/stock_fit_rank_title"
        app:titleTextColor="@android:color/white" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/fitRankAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:fitsSystemWindows="false"
            app:elevation="0dp"
            app:liftOnScroll="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:layout_scrollFlags="scroll|enterAlways|snap"
                app:strokeColor="@color/fit_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:text="@string/stock_fit_rank_hint"
                        android:textColor="@color/yd_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:hint="@string/stock_fit_rank_lookback_days">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/lookbackDaysEt"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/stock_pair_fit_end_date">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/endDateEt"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/networkCb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:checked="false"
                        android:text="@string/stock_fit_rank_network_anchor"
                        android:textColor="@color/yd_body"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/endDatePrevDayBtn"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/stock_fit_rank_end_prev_day"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            app:cornerRadius="10dp"
                            app:strokeColor="@color/yd_accent"
                            app:strokeWidth="1dp" />

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/runBtn"
                                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:insetLeft="0dp"
                                android:insetRight="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:paddingHorizontal="4dp"
                                android:text="@string/stock_fit_rank_run"
                                android:textAllCaps="false"
                                android:textColor="@color/fit_cta_text"
                                android:textSize="13sp"
                                app:backgroundTint="@color/fit_cta_bg"
                                app:cornerRadius="10dp"
                                app:rippleColor="@color/fit_cta_ripple" />

                            <com.liaobusi.stockman.RoundedRectBorderLoadingView
                                android:id="@+id/queryBtnBorderLoading"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:visibility="gone"
                                tools:visibility="visible" />
                        </FrameLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/endDateNextDayBtn"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@string/stock_fit_rank_end_next_day"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            app:cornerRadius="10dp"
                            app:strokeColor="@color/yd_accent"
                            app:strokeWidth="1dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/statusTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_fit_status"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:textColor="@color/yd_secondary"
                        android:textSize="12sp"
                        tools:text="状态" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="16dp"
            android:scrollbars="vertical"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
