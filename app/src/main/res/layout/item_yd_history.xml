<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:clickable="false"
    android:focusable="false"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:rippleColor="#26BD2C2C"
    app:strokeColor="#14000000"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/dateTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:letterSpacing="0.02"
                        android:maxLines="1"
                        android:textColor="@color/yd_accent"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        tools:text="2024-01-15" />

                    <FrameLayout
                        android:id="@+id/popularityHeatContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_yd_popularity_sphere"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="5dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/popularityHeatTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:shadowColor="#80000000"
                            android:shadowDx="0"
                            android:shadowDy="1"
                            android:shadowRadius="2"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="128" />
                    </FrameLayout>
                </LinearLayout>



                <TextView
                    android:id="@+id/timeTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_yd_time_chip"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/yd_secondary"
                    android:textSize="13sp"
                    tools:text="09:35:00" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ydDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/yd_divider" />

                <LinearLayout
                    android:id="@+id/groupSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="板块"
                        android:textColor="@color/yd_caption"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/groupTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/yd_body"
                        android:textSize="15sp"
                        tools:text="人工智能" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reasonSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="异动原因"
                        android:textColor="@color/yd_caption"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/reasonTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/yd_body"
                        android:textSize="15sp"
                        tools:text="涨停复盘" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/expoundSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="说明"
                        android:textColor="@color/yd_caption"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/expoundTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/yd_secondary"
                        android:textSize="14sp"
                        tools:text="详细说明文字" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/unusualSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_yd_unusual_section"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="14dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_yd_unusual_accent_bar"
                        android:minHeight="36dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.03"
                            android:text="@string/yd_unusual_section_title"
                            android:textColor="@color/yd_accent"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/unusualTv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="5dp"
                            android:textColor="@color/yd_body"
                            android:textSize="15sp"
                            tools:text="资讯内容聚合" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/expandToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="10dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/expandLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yd_accent"
                    android:textSize="14sp"
                    tools:text="展开" />

                <ImageView
                    android:id="@+id/expandIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@string/yd_expand_toggle"
                    android:padding="1dp"
                    android:src="@drawable/ic_yd_expand_24" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/ztWatermark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="10dp"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:rotation="-16"
            android:text="涨停"
            android:textColor="#33BD2C2C"
            android:textSize="52sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
